APP_NAME="Ibrahim Hasan"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file


BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
N8N_LOG_WEBHOOK_URL=
N8N_LOG_WEBHOOK_TOKEN=
N8N_LOG_PROJECT="Ibrahim Hasan"
N8N_LOG_LEVEL=warning
N8N_LOG_TIMEOUT=3

ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_MAX_CHARACTERS=9000
ELEVENLABS_CONTEXT_CHARACTERS=400
ELEVENLABS_STABILITY=0.72
ELEVENLABS_SIMILARITY_BOOST=0.78
ELEVENLABS_STYLE=0.08
ELEVENLABS_SPEED=0.96
ELEVENLABS_SPEAKER_BOOST=true
ELEVENLABS_AUDIO_DISK=public
ELEVENLABS_QUEUE_CONNECTION=database
ELEVENLABS_QUEUE=article-audio
ELEVENLABS_TIMEOUT=150
ELEVENLABS_CONNECT_TIMEOUT=15
ELEVENLABS_TEXT_NORMALIZATION=on

DB_CONNECTION=sqlite
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_QUEUE_RETRY_AFTER=420

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379


MAIL_MAILER=
MAIL_SCHEME=
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
ENABLE_PHASE_2=
OPENAI_API_KEY=
